# .env.example — copy to .env and fill in your values

NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# Supabase (https://supabase.com/dashboard/project/_/settings/api)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# JWT (must match Supabase JWT secret)
JWT_SECRET=your-super-secret-jwt-key-at-least-32-chars

# Deepgram STT (https://console.deepgram.com)
DEEPGRAM_API_KEY=your-deepgram-api-key

# OpenAI Whisper fallback (optional)
OPENAI_API_KEY=

# Gemini LLM (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash

# Rate limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# WebSocket
WS_PING_INTERVAL_MS=30000
WS_MAX_PAYLOAD_BYTES=1048576

# STT config
STT_TARGET_LATENCY_MS=2000
STT_LANGUAGE=en-US

# RAG / embeddings
EMBEDDING_CHUNK_SIZE=500
EMBEDDING_CHUNK_OVERLAP=50
