{
  "name": "meetflow-backend",
  "version": "1.0.0",
  "description": "MeetFlow AI — Backend API & WebSocket server for real-time meeting transcription and AI co-pilot",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "db:migrate": "supabase db push",
    "db:generate": "supabase gen types typescript --local > src/types/supabase.ts"
  },
  "dependencies": {
    "@deepgram/sdk": "^3.3.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^8.3.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@fastify/websocket": "^10.0.1",
    "@google/generative-ai": "^0.21.0",
    "@supabase/supabase-js": "^2.45.4",
    "fastify": "^5.7.4",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^4.0.18"
  }
}
